# Server
NODE_ENV=production
PORT=5000
APP_URL=https://yourdomain.com
APP_DOWNLOAD_URL=https://yourdomain.com/download

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/rk_electronics?retryWrites=true&w=majority

# JWT Secrets
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_REFRESH_SECRET=your_refresh_jwt_secret_here_change
JWT_TEMP_SECRET=your_temp_jwt_secret_here_change
JWT_RESET_SECRET=your_reset_jwt_secret_here_change
JWT_EXPIRY=30d

# OTP Settings
OTP_EXPIRY_MINUTES=10
MAX_DAILY_OTP=10
MAX_HOURLY_OTP=5

# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="RK Electronics <noreply@rkelectronics.com>"

# SMS Service
SMS_PROVIDER=test
TWILIO_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_NUMBER=+1234567890

# Security
CORS_ORIGIN=https://yourapp.com,https://admin.yourapp.com

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
